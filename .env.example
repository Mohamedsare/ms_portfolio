# URL du site (SEO, partage, redirection CV)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (tableau Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clé service : réservée au serveur (Route Handler / contact). Ne jamais exposer au client.
# Si elle est absente, l’API contact utilisera la clé anon (nécessite la policy contact_insert_public).
SUPABASE_SERVICE_ROLE_KEY=

# Lien direct vers le PDF du CV (optionnel). Sinon redirection vers /cv.pdf dans public/
NEXT_PUBLIC_CV_URL=
